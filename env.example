# ================================================================
# FICHIER ENVIRONNEMENT - REMPLISSEZ VOS VALEURS
# ================================================================

# DATABASE
DATABASE_URL=postgresql://cresus_app:password@localhost:5432/cresus_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cresus_db
DB_USER=cresus_app
DB_PASSWORD=your_secure_password

# SERVER
PORT=5000
NODE_ENV=production
LOG_LEVEL=info

# CLAUDE API
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxx

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# TWILIO (Optional - pour SMS)
TWILIO_ACCOUNT_SID=xxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_PHONE=+33xxxxxxxxx

# FIREBASE (Optional - pour push notifications)
FIREBASE_PROJECT_ID=xxxxx
FIREBASE_PRIVATE_KEY=xxxxx
FIREBASE_CLIENT_EMAIL=xxxxx@firebase.gserviceaccount.com

# MAIL
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=notifications@cresus.fr
MAIL_PASSWORD=app_password_here

# SENTRY (Optional - error tracking)
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# CORS
CORS_ORIGIN=https://cresus-suivi.fr

# RATE LIMIT
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
